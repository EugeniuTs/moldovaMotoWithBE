# ── Admin Credentials ────────────────────────────────────────────────────────
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=change_me_before_deploy

# ── Backend API ──────────────────────────────────────────────────────────────
# Secret key for admin API operations (update bookings, delete, list all)
# Set the same value in BOTH the API container env and here for the frontend.
API_ADMIN_KEY=change-me-to-a-long-random-secret

# Frontend reads this to know where the API is
# In dev:  http://localhost:4000/api
# In prod: /api  (nginx proxies it)
VITE_API_URL=/api
VITE_API_ADMIN_KEY=${API_ADMIN_KEY}

# ── Brevo (transactional email + WhatsApp) ───────────────────────────────────
VITE_BREVO_API_KEY=your_brevo_api_key_here
VITE_FROM_EMAIL=bookings@moldovamoto.com
VITE_FROM_NAME=MoldovaMoto
VITE_NOTIFY_EMAIL=admin@moldovamoto.com
VITE_NOTIFY_WHATSAPP=+37379000000

# WhatsApp Business sender number — must be registered in Brevo → WhatsApp → Senders
# Go to: https://app.brevo.com → WhatsApp → Senders → Add a sender
VITE_NOTIFY_WHATSAPP_SENDER=+37369765298
