# ─── Admin Credentials ────────────────────────────────────────────────────────
# Both are REQUIRED — the admin login will fail if either is blank.
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=change_me_before_deploy

# ─── Brevo (transactional email + WhatsApp) ───────────────────────────────────
# Get your API key from: https://app.brevo.com → Settings → API Keys
VITE_BREVO_API_KEY=your_brevo_api_key_here

# Email address verified in Brevo (Settings → Senders & IP)
VITE_FROM_EMAIL=bookings@moldovamoto.com
VITE_FROM_NAME=MoldovaMoto

# Admin inbox — receives all booking and contact form alerts
VITE_NOTIFY_EMAIL=admin@moldovamoto.com

# WhatsApp number to receive alerts (include country code, digits only OK)
# Must be registered in Brevo → WhatsApp → Senders
VITE_NOTIFY_WHATSAPP=+37379000000
